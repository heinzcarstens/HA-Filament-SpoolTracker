# SpoolTracker standalone Docker (docker-compose.standalone.yml)
# Copy to .env and fill in your values:
#   cp .env.example .env

# Required for HA integration
HOME_ASSISTANT_URL=http://YOUR_HA_HOST:8123
SUPERVISOR_TOKEN=your_long_lived_access_token

# Optional (defaults shown)
PORT=3000
# Host path for DB and cache (default: ./data so app.db lives outside the container)
# DATA_PATH=./data
# DATABASE_URL=file:/data/app.db
# LOG_LEVEL=info

# Optional: use a file for the token instead of SUPERVISOR_TOKEN (mount the file in docker-compose)
# SUPERVISOR_TOKEN_FILE=/run/token
